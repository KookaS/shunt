# Copy to `.env` (gitignored — never committed) and fill in your keys.
#
# Loaded automatically by:
#   - the benchmark:  `python -m benchmark.runner.run_matrix --live`
#   - the router CLI: `shunt start`
#   - the wrapper Makefile launchers (`make opencode` / `opencode-wt`)
# Real environment variables always take precedence over this file.
#
# Direct-provider models (access_via: direct in models.json) read their own key;
# requesty-routed models share REQUESTY_API_KEY.
DEEPSEEK_API_KEY=
REQUESTY_API_KEY=
XAI_API_KEY=
