# Copy to `.env` (gitignored — never committed) and fill in your keys.
#
# Loaded automatically by:
#   - the benchmark:  `python -m benchmark.runner.run_matrix --live`
#   - the router CLI: `shunt start`
#   - the wrapper Makefile launchers (`make opencode` / `opencode-wt`)
# Real environment variables always take precedence over this file.
#
# Each provider row in the registry names the variable it reads
# (`api_key_env_var` in src/shunt/config/models.yaml). Set the ones you
# use; the rest are ignored. See docs/configuration.md.

# Aggregators — one key, many vendors.
REQUESTY_API_KEY=
OPENROUTER_API_KEY=

# First-party.
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=

# Open-weight serving.
GROQ_API_KEY=
TOGETHER_API_KEY=
CEREBRAS_API_KEY=
NEBIUS_API_KEY=
FIREWORKS_API_KEY=

# Local (Ollama / vLLM) needs no key — see examples/providers/local.yaml.
