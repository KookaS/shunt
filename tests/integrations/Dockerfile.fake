# The happy-path fake upstream, as a tiny container for the Docker handshake
# matrix. Build context is THIS directory (tests/integrations/) — not the repo
# root, whose .dockerignore excludes tests/.
FROM python:3.12-slim
WORKDIR /app
COPY fake_upstream.py .
ENV FAKE_UPSTREAM_PORT=9099
EXPOSE 9099
CMD ["python", "fake_upstream.py"]
